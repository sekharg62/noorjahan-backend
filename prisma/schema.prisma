generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  admin
  staff
}

enum BannerType {
  HOME
  CATEGORY
  PRODUCT
}

model Admin {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         AdminRole @default(admin)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("admins")
}

model MenuSubmenu {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  slug      String        @unique
  parentId  String?       @map("parent_id") @db.Uuid
  parent    MenuSubmenu?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuSubmenu[] @relation("MenuHierarchy")
  products  Product[]
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([parentId])
  @@map("menu_submenu")
}

model Product {
  id            String         @id @default(uuid()) @db.Uuid
  menuSubmenuId String         @map("menu_submenu_id") @db.Uuid
  menuSubmenu   MenuSubmenu    @relation(fields: [menuSubmenuId], references: [id], onDelete: Cascade)
  name          String
  slug          String         @unique
  description   String?
  price         String
  offerPrice    String?        @map("offer_price")
  stock         Int            @default(0)
  isActive      Boolean        @default(true) @map("is_active")
  images        ProductImage[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([menuSubmenuId])
  @@map("products")
}

model ProductImage {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imgUrl       String   @map("img_url")
  displayOrder Int      @map("display_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([productId, displayOrder])
  @@index([productId])
  @@map("product_img")
}

model Banner {
  id          String     @id @default(uuid()) @db.Uuid
  imgUrl      String     @map("img_url")
  redirectUrl String?    @map("redirect_url")
  order       Int        @unique
  type        BannerType @default(HOME)
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("banners")
}

model Customer {
  id           String            @id @default(uuid()) @db.Uuid
  name         String
  email        String?           @unique
  phone        String            @unique
  passwordHash String            @map("password_hash")
  addresses    CustomerAddress[]
  createdAt    DateTime          @default(now()) @map("created_at")

  @@map("customers")
}

model CustomerAddress {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address       String
  city          String
  pincode       String
  alternativePh String?  @map("alternative_ph")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@map("customer_address")
}

